# ─────────────────────────────────────────────────────
# StockSystem — Variables de entorno
# Copiá este archivo a .env y completá los valores
# ─────────────────────────────────────────────────────

# Base de datos MySQL (cPanel → MySQL Databases)
# Formato: mysql://USUARIO:CONTRASEÑA@localhost:3306/NOMBRE_DB
DATABASE_URL="mysql://stockuser:password123@localhost:3306/stocksystem"

# NextAuth — clave secreta (generá una con: openssl rand -base64 32)
NEXTAUTH_SECRET="reemplaza-esto-con-una-clave-secreta-larga"

# URL pública de tu sitio (sin barra final)
NEXTAUTH_URL="https://tudominio.com"

# Puerto en el que corre la app (cPanel lo asigna automáticamente)
PORT=3000
